# Sarathy Environment Configuration Example
# Copy this file to '.env' and fill in your values.

# The API key for Sarvam AI
SARVAM_API_KEY=your-sarvam-api-key-here

# (Optional) Base API endpoint URL. Defaults to 'https://api.sarvam.ai/v1'
# SARVAM_API_BASE=https://api.sarvam.ai/v1

# (Optional) Model name to use for agentic reasoning. Defaults to 'sarvam-105b'
# SARVAM_MODEL=sarvam-105b
